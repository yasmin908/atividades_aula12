#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int vetor[25];

    // Inicializa a semente dos números aleatórios
    srand(time(NULL));

    // Preenche o vetor com valores aleatórios de 0 a 100
    for(int i = 0; i < 25; i++) {
        vetor[i] = rand() % 101;
    }

    // Exibe o vetor
    printf("Vetor com 25 valores aleatorios:\n\n");
    for(int i = 0; i < 25; i++) {
        printf("%3d ", vetor[i]);
    }

    printf("\n");

    return 0;
}
