#include <stdio.h>

int main() {
    char nomes[5][50];

    // Entrada dos nomes
    for(int i = 0; i < 5; i++) {
        printf("Digite o nome da posicao %d: ", i);
        scanf(" %[^\n]", nomes[i]); // lê nome com espaços
    }

    // Exibe os nomes
    printf("\nNomes digitados:\n");
    for(int i = 0; i < 5; i++) {
        printf("%s\n", nomes[i]);
    }

    return 0;
}
