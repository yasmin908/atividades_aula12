#include <stdio.h>

int main() {
    int vetor[10];
    int i;
    int maior, menor;

    // Entrada dos números
    for(i = 0; i < 10; i++) {
        printf("Digite o numero %d: ", i + 1);
        scanf("%d", &vetor[i]);
    }

    // Inicializa com o primeiro elemento
    maior = vetor[0];
    menor = vetor[0];

    // Procura maior e menor
    for(i = 1; i < 10; i++) {
        if(vetor[i] > maior) {
            maior = vetor[i];
        }
        if(vetor[i] < menor) {
            menor = vetor[i];
        }
    }

    // Exibe resultados
    printf("\nMaior numero: %d\n", maior);
    printf("Menor numero: %d\n", menor);

    return 0;
}
