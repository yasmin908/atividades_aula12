#include <stdio.h>

int main() {
    int vetor[10];
    int i;
    int maior;

    // Entrada dos números
    for(i = 0; i < 10; i++) {
        printf("Digite o numero %d: ", i + 1);
        scanf("%d", &vetor[i]);
    }

    // Inicializa o maior com o primeiro elemento
    maior = vetor[0];

    // Procura o maior número
    for(i = 1; i < 10; i++) {
        if(vetor[i] > maior) {
            maior = vetor[i];
        }
    }

    // Exibe o resultado
    printf("\nMaior numero digitado: %d\n", maior);

    return 0;
}
