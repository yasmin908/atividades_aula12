# atividades_aula12
#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int matriz[5][5];
    
    // Inicializa a semente para números aleatórios
    srand(time(NULL));

    // Preenche a matriz com números aleatórios de 0 a 100
    for(int i = 0; i < 5; i++) {
        for(int j = 0; j < 5; j++) {
            matriz[i][j] = rand() % 101;
        }
    }

    // Exibe a matriz
    printf("Matriz 5x5 com valores aleatorios:\n\n");
    for(int i = 0; i < 5; i++) {
        for(int j = 0; j < 5; j++) {
            printf("%3d ", matriz[i][j]);
        }
        printf("\n");
    }

    return 0;
}
