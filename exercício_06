#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int matriz[5][5];
    int numero;
    int encontrado = 0;

    srand(time(NULL));

    // Preenche a matriz com números aleatórios
    for(int i = 0; i < 5; i++) {
        for(int j = 0; j < 5; j++) {
            matriz[i][j] = rand() % 101;
        }
    }

    // Mostra a matriz
    printf("Matriz 5x5:\n\n");
    for(int i = 0; i < 5; i++) {
        for(int j = 0; j < 5; j++) {
            printf("%3d ", matriz[i][j]);
        }
        printf("\n");
    }

    // Solicita número ao usuário
    printf("\nDigite um numero para buscar na matriz: ");
    scanf("%d", &numero);

    // Procura o número na matriz
    for(int i = 0; i < 5; i++) {
        for(int j = 0; j < 5; j++) {
            if(matriz[i][j] == numero) {
                printf("Numero encontrado na posicao: linha %d, coluna %d\n", i, j);
                encontrado = 1;
            }
        }
    }

    // Caso não encontrado
    if(encontrado == 0) {
        printf("Numero nao encontrado na matriz.\n");
    }

    return 0;
}
