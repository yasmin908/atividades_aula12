#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int matriz[5][5];
    int menor, linha, coluna;

    srand(time(NULL));

    // Preenche a matriz
    for(int i = 0; i < 5; i++) {
        for(int j = 0; j < 5; j++) {
            matriz[i][j] = rand() % 101;
        }
    }

    // Inicializa com o primeiro elemento
    menor = matriz[0][0];
    linha = 0;
    coluna = 0;

    // Exibe a matriz e encontra o menor valor
    printf("Matriz 5x5:\n\n");
    for(int i = 0; i < 5; i++) {
        for(int j = 0; j < 5; j++) {
            printf("%3d ", matriz[i][j]);

            if(matriz[i][j] < menor) {
                menor = matriz[i][j];
                linha = i;
                coluna = j;
            }
        }
        printf("\n");
    }

    printf("\nMenor valor: %d\n", menor);
    printf("Posicao: linha %d, coluna %d\n", linha, coluna);

    return 0;
}
