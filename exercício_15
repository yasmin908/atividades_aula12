#include <stdio.h>
#include <string.h>

int main() {
    char nomes[5][50];
    char temp[50];
    int i, j;

    // Entrada dos nomes
    for(i = 0; i < 5; i++) {
        printf("Digite o nome %d: ", i + 1);
        scanf(" %[^\n]", nomes[i]);
    }

    // Ordenação em ordem alfabética (Bubble Sort)
    for(i = 0; i < 4; i++) {
        for(j = 0; j < 4 - i; j++) {
            if(strcmp(nomes[j], nomes[j + 1]) > 0) {
                strcpy(temp, nomes[j]);
                strcpy(nomes[j], nomes[j + 1]);
                strcpy(nomes[j + 1], temp);
            }
        }
    }

    // Exibe os nomes ordenados
    printf("\nNomes em ordem alfabética:\n");
    for(i = 0; i < 5; i++) {
        printf("%s\n", nomes[i]);
    }

    return 0;
}
