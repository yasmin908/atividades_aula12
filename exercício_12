#include <stdio.h>

int main() {
    int vetor[10];
    int i, j, temp;

    // Entrada dos números
    for(i = 0; i < 10; i++) {
        printf("Digite o numero %d: ", i + 1);
        scanf("%d", &vetor[i]);
    }

    // Ordenação (Bubble Sort - crescente)
    for(i = 0; i < 9; i++) {
        for(j = 0; j < 9 - i; j++) {
            if(vetor[j] > vetor[j + 1]) {
                temp = vetor[j];
                vetor[j] = vetor[j + 1];
                vetor[j + 1] = temp;
            }
        }
    }

    // Exibe em ordem crescente
    printf("\nOrdem crescente:\n");
    for(i = 0; i < 10; i++) {
        printf("%d ", vetor[i]);
    }

    // Exibe em ordem decrescente
    printf("\n\nOrdem decrescente:\n");
    for(i = 9; i >= 0; i--) {
        printf("%d ", vetor[i]);
    }

    printf("\n");

    return 0;
}
