#include <stdio.h>

int main() {
    int vetor[5];

    // Entrada dos valores
    for(int i = 0; i < 5; i++) {
        printf("Digite o valor da posicao %d: ", i);
        scanf("%d", &vetor[i]);
    }

    // Exibe em ordem inversa
    printf("\nValores em ordem inversa:\n");
    for(int i = 4; i >= 0; i--) {
        printf("%d ", vetor[i]);
    }

    printf("\n");

    return 0;
}
